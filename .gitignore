# =============================================================================
# 🔒 DCHAL STORE — SUPER PRIVATE .gitignore
# =============================================================================
# File ini melindungi semua data sensitif, credentials, dan file lokal
# dari ter-commit ke repository. JANGAN HAPUS BARIS APAPUN tanpa paham
# konsekuensinya.
# =============================================================================


# =============================================================================
# 🚨 CRITICAL — ENVIRONMENT & SECRETS
# =============================================================================
# Semua file .env yang berisi API keys, JWT secret, password DB, dll.
# Kalau ini bocor ke public repo, akun Midtrans/Biteship/DB bisa dibajak.
fronten/.env
backend/.env
ADMIN_GUIDE.md
README_.md
.claude
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Environment specific
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging
.env.production
.env.production.local

# Backup env files (sering bocor!)
.env.backup
.env.bak
.env.old
.env.orig
.env.save
*.env
env.json
env.yaml
env.yml
config.local.*


