# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (gunakan MongoDB Compass / Atlas / lokal)
MONGO_URI=mongodb://localhost:27017/dchal_store
# Untuk MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dchal_store

# JWT Secret
JWT_SECRET=dchal_store_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Midtrans (daftar di https://midtrans.com - gunakan Sandbox dulu)
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXX
MIDTRANS_IS_PRODUCTION=false

# Biteship (daftar di https://biteship.com)
BITESHIP_API_KEY=biteship_test.XXXXXXXXXXXXXXXX
BITESHIP_BASE_URL=https://api.biteship.com

# Store Origin (alamat asal pengiriman dari toko Anda)
STORE_ORIGIN_AREA_ID=IDNP6IDNC150IDND2192IDZ17530
STORE_ORIGIN_POSTAL_CODE=17530
STORE_LATITUDE=-6.2615
STORE_LONGITUDE=107.1526

# Frontend URL (untuk CORS dan callback Midtrans)
FRONTEND_URL=http://localhost:5173
